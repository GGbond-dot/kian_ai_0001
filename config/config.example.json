      "tool": "vision.set_camera",
      "ack": "",
      "args": { "enable": true }
    },
    "camera_off": {
      "keywords": ["关闭摄像头", "关掉摄像头", "关视频", "关闭视频", "关摄像头"],
      "tool": "vision.set_camera",
      "ack": "",
      "args": { "enable": false }
    }
