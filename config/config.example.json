    "dashscope_api_key": "${DASHSCOPE_API_KEY}",
    "dashscope_base_url": "https://dashscope.aliyuncs.com/api/v1",
    "qwen_model": "qwen3-tts-flash",
    "qwen_voice": "Cherry",
    "qwen_language_type": "Chinese",
    "qwen_instructions": "",
    "qwen_optimize_instructions": false,
